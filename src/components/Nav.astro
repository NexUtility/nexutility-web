---
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const links = [
  { href: "/apps", label: "Products" },
  { href: "/support", label: "Support" },
  { href: "/contact", label: "Contact" },
];
const isActive = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
---

<header
  class="sticky top-0 z-40 border-b border-border/60 bg-bg/70 backdrop-blur-xl backdrop-saturate-150"
>
  <div class="container-page flex h-16 items-center justify-between">
    <a
      href="/"
      class="group inline-flex min-h-[44px] items-center gap-2.5 px-1 font-semibold tracking-tight"
      aria-label="NexUtility — home"
    >
      <span
        class="grid h-7 w-7 place-items-center rounded-md bg-accent text-accent-foreground transition-transform group-hover:rotate-3"
      >
        <svg
          width="14"
          height="14"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M2 12.5V3.5L8 8L14 3.5V12.5"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
      <span class="text-fg">NexUtility</span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-1 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "inline-flex min-h-[44px] items-center rounded-md px-3 text-sm transition-colors",
              isActive(link.href)
                ? "text-fg bg-bg-elev"
                : "text-fg-muted hover:text-fg hover:bg-bg-elev/60",
            ]}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="/apps"
        class="hidden min-h-[44px] items-center rounded-md bg-accent px-4 text-sm font-medium text-accent-foreground transition-colors hover:bg-accent-hover sm:inline-flex"
      >
        See what we're building
      </a>
      <button
        type="button"
        id="nav-toggle"
        class="grid h-11 w-11 place-items-center rounded-md text-fg-muted hover:text-fg hover:bg-bg-elev md:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-mobile"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M4 7h16M4 12h16M4 17h16"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          ></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="nav-mobile"
    hidden
    class="border-t border-border/60 md:hidden"
  >
    <nav aria-label="Mobile" class="container-page flex flex-col py-2">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "inline-flex min-h-[44px] items-center rounded-md px-3 text-sm transition-colors",
              isActive(link.href) ? "text-fg bg-bg-elev" : "text-fg-muted hover:text-fg",
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("nav-toggle");
  const menu = document.getElementById("nav-mobile");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const open = menu.hasAttribute("hidden");
      if (open) {
        menu.removeAttribute("hidden");
        btn.setAttribute("aria-expanded", "true");
        btn.setAttribute("aria-label", "Close menu");
        // Move focus to first menu link for keyboard users.
        const firstLink = menu.querySelector("a");
        if (firstLink instanceof HTMLElement) firstLink.focus();
      } else {
        menu.setAttribute("hidden", "");
        btn.setAttribute("aria-expanded", "false");
        btn.setAttribute("aria-label", "Open menu");
        btn.focus();
      }
    });
  }
</script>
