---
import type { App } from "../data/apps";

interface Props {
  app: App;
}

const { app } = Astro.props;

const statusBadge = {
  live: { label: "Live", classes: "bg-success/15 text-success border-success/30" },
  beta: { label: "Beta", classes: "bg-warning/15 text-warning border-warning/30" },
  soon: { label: "Coming soon", classes: "bg-fg-subtle/15 text-fg-muted border-border" },
}[app.status];
---

<article
  class="group relative flex flex-col overflow-hidden rounded-xl border border-border bg-bg-elev/40 p-6 transition-all hover:border-border-strong hover:bg-bg-elev"
>
  <div class="flex items-start justify-between gap-4">
    <div
      class="grid h-12 w-12 shrink-0 place-items-center rounded-lg bg-bg-elev-2 border border-border text-2xl"
      aria-hidden="true"
    >
      {app.icon}
    </div>
    <span
      class:list={[
        "inline-flex items-center rounded-full border px-2.5 py-0.5 text-[11px] font-medium tracking-wide uppercase",
        statusBadge.classes,
      ]}
    >
      {statusBadge.label}
    </span>
  </div>

  <h3 class="mt-5 text-lg font-semibold tracking-tight text-fg">
    {app.name}
  </h3>
  <p class="mt-1.5 text-sm leading-relaxed text-fg-muted">
    {app.tagline}
  </p>

  {
    app.platforms && app.platforms.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-1.5">
        {app.platforms.map((p) => (
          <span class="inline-flex items-center gap-1 rounded-md border border-border bg-bg-elev px-2 py-0.5 text-[11px] font-mono text-fg-muted">
            {p}
          </span>
        ))}
      </div>
    )
  }

  <div class="mt-6 flex flex-wrap items-center gap-3 text-sm">
    {
      app.appStoreUrl && (
        <a
          href={app.appStoreUrl}
          class="inline-flex items-center gap-1.5 text-fg-muted transition-colors hover:text-fg"
          rel="noopener"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z" />
          </svg>
          <span>App Store</span>
        </a>
      )
    }
    {
      app.playStoreUrl && (
        <a
          href={app.playStoreUrl}
          class="inline-flex items-center gap-1.5 text-fg-muted transition-colors hover:text-fg"
          rel="noopener"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734c0-.376.235-.7.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.198l2.807 1.626a1 1 0 010 1.73l-2.808 1.626L15.183 12l2.515-2.491zM5.864 1.665L16.8 7.999l-2.302 2.301-8.635-8.635z" />
          </svg>
          <span>Google Play</span>
        </a>
      )
    }
  </div>
</article>
