---
const year = new Date().getFullYear();
const sections = [
  {
    title: "Product",
    links: [
      { href: "/apps", label: "Apps catalog" },
      { href: "/support", label: "Support" },
      { href: "/contact", label: "Contact" },
    ],
  },
  {
    title: "Legal",
    links: [
      { href: "/privacy", label: "Privacy Policy" },
      { href: "/terms", label: "Terms of Service" },
    ],
  },
];
---

<footer class="mt-32 border-t border-border/60">
  <div class="container-page py-16">
    <div class="grid gap-12 md:grid-cols-[1.5fr_1fr_1fr]">
      <div>
        <a href="/" class="flex items-center gap-2.5 font-semibold tracking-tight">
          <span class="grid h-7 w-7 place-items-center rounded-md bg-accent text-accent-foreground">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path
                d="M2 12.5V3.5L8 8L14 3.5V12.5"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <span>NexUtility</span>
        </a>
        <p class="mt-4 max-w-xs text-sm text-fg-muted">
          Tools designed for human hands. Software that respects your
          attention, your data, and the way you actually live.
        </p>
      </div>

      {
        sections.map((section) => (
          <div>
            <h3 class="text-sm font-medium text-fg">{section.title}</h3>
            <ul class="mt-4 space-y-2.5">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-fg-muted underline-offset-4 transition-colors hover:text-fg hover:underline"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-border/60 pt-6 text-xs text-fg-subtle sm:flex-row sm:items-center"
    >
      <p>© {year} NexUtility. All rights reserved.</p>
      <p class="font-mono">Designed and built in Türkiye.</p>
    </div>
  </div>
</footer>
