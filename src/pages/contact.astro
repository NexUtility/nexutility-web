---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Reach the NexUtility team — partnerships, press, and general questions."
>
  <section class="container-page pt-16 pb-24 md:pt-24 md:pb-32">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_1fr] lg:items-start">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-fg-muted">
          Contact
        </p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">
          Talk to a real human.
        </h1>
        <p class="mt-5 max-w-md text-fg-muted md:text-lg">
          Whether you're a user with a stuck subscription, a journalist working
          on a story, or another studio looking to collaborate — drop us a
          line. We answer email, not bots.
        </p>

        <ul class="mt-10 space-y-1 font-mono text-sm">
          <li class="flex items-baseline gap-3">
            <span class="text-fg-muted">support</span>
            <a
              href="mailto:support@nexutility.dev"
              class="text-fg underline-offset-4 hover:underline"
              >support@nexutility.dev</a
            >
          </li>
          <li class="flex items-baseline gap-3">
            <span class="text-fg-muted">privacy</span>
            <a
              href="mailto:privacy@nexutility.dev"
              class="text-fg underline-offset-4 hover:underline"
              >privacy@nexutility.dev</a
            >
          </li>
          <li class="flex items-baseline gap-3">
            <span class="text-fg-muted">press &nbsp;</span>
            <a
              href="mailto:hello@nexutility.dev"
              class="text-fg underline-offset-4 hover:underline"
              >hello@nexutility.dev</a
            >
          </li>
        </ul>
      </div>

      <div class="rounded-xl border border-border bg-bg-elev/40 p-6 md:p-8">
        <h2 class="text-lg font-semibold text-fg">Quick links</h2>
        <p class="mt-1.5 text-sm text-fg-muted">
          Most questions are faster answered here.
        </p>
        <div class="mt-6 flex flex-col gap-2">
          <a
            href="/support"
            class="group flex items-center justify-between rounded-md border border-border bg-bg/40 px-4 py-3 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Support FAQ</span>
            <span class="text-fg-muted group-hover:text-accent">→</span>
          </a>
          <a
            href="/apps"
            class="group flex items-center justify-between rounded-md border border-border bg-bg/40 px-4 py-3 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Apps catalog</span>
            <span class="text-fg-muted group-hover:text-accent">→</span>
          </a>
          <a
            href="/privacy"
            class="group flex items-center justify-between rounded-md border border-border bg-bg/40 px-4 py-3 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Privacy Policy</span>
            <span class="text-fg-muted group-hover:text-accent">→</span>
          </a>
          <a
            href="/terms"
            class="group flex items-center justify-between rounded-md border border-border bg-bg/40 px-4 py-3 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Terms of Service</span>
            <span class="text-fg-muted group-hover:text-accent">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
