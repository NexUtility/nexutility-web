---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqs = [
  {
    q: "How do I cancel a subscription?",
    a: "Subscriptions are managed by Apple or Google. On iPhone or iPad, open Settings → tap your name → Subscriptions. On Android, open the Play Store app → tap your profile picture → Payments & subscriptions → Subscriptions. Cancellation takes effect at the end of the current billing period.",
  },
  {
    q: "I was charged but I don't see my purchase.",
    a: "Open the app and tap 'Restore purchases' on the paywall or in Settings. Restore re-checks your App Store / Play Store receipt and re-enables an active subscription. If that doesn't fix it, email us with your purchase receipt and we'll get it sorted within one business day.",
  },
  {
    q: "How do I request a refund?",
    a: "We don't process refunds directly — Apple and Google handle them. For Apple, visit reportaproblem.apple.com. For Google, open Play Store → Menu → My Apps → tap the app → Refund. We can help you find the right form if you write to us.",
  },
  {
    q: "How do I delete my data?",
    a: "Most of our apps store everything on your device, so uninstalling deletes your data. If an app uses cloud sync or accounts, email privacy@nexutility.com from the address on file and we'll erase your account and associated data within 30 days.",
  },
  {
    q: "How do I report a bug or request a feature?",
    a: "Open an issue from the app's settings (most apps have a 'Send feedback' option) or write to support@nexutility.com. Include your device model, OS version, and the app version (visible in the app's Settings → About).",
  },
];
---

<BaseLayout
  title="Support"
  description="Help and contact options for NexUtility apps. Cancel subscriptions, restore purchases, request refunds, or report bugs."
>
  <section class="container-page pt-16 pb-10 md:pt-24 md:pb-12">
    <div class="max-w-2xl">
      <p class="font-mono text-xs uppercase tracking-widest text-fg-subtle">Support</p>
      <h1 class="mt-3 text-4xl font-semibold tracking-tight md:text-5xl">
        We're here to help.
      </h1>
      <p class="mt-5 text-fg-muted md:text-lg">
        Reach the team directly, or check the answers to the questions we get
        most often.
      </p>
    </div>
  </section>

  <section class="container-page pb-16">
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <a
        href="mailto:support@nexutility.com"
        class="group rounded-xl border border-border bg-bg-elev/40 p-6 transition-all hover:border-border-strong hover:bg-bg-elev"
      >
        <div
          class="grid h-10 w-10 place-items-center rounded-md bg-accent/10 text-accent"
          aria-hidden="true"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path
              d="M3 8.5V17a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.5M3 8.5l8.4 5.6a1 1 0 0 0 1.2 0L21 8.5M3 8.5V7a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v1.5"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h2 class="mt-5 text-base font-semibold text-fg">General support</h2>
        <p class="mt-1.5 text-sm text-fg-muted">
          Bugs, billing, account questions. We reply within 1 business day.
        </p>
        <p class="mt-4 font-mono text-sm text-fg group-hover:text-accent">
          support@nexutility.com
        </p>
      </a>

      <a
        href="mailto:privacy@nexutility.com"
        class="group rounded-xl border border-border bg-bg-elev/40 p-6 transition-all hover:border-border-strong hover:bg-bg-elev"
      >
        <div
          class="grid h-10 w-10 place-items-center rounded-md bg-accent/10 text-accent"
          aria-hidden="true"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path
              d="M12 3 4 6.5v5c0 4.5 3.2 8.7 8 10 4.8-1.3 8-5.5 8-10v-5L12 3Z"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h2 class="mt-5 text-base font-semibold text-fg">Privacy & data</h2>
        <p class="mt-1.5 text-sm text-fg-muted">
          Access, export, or erase your data. GDPR / KVKK requests.
        </p>
        <p class="mt-4 font-mono text-sm text-fg group-hover:text-accent">
          privacy@nexutility.com
        </p>
      </a>

      <a
        href="mailto:legal@nexutility.com"
        class="group rounded-xl border border-border bg-bg-elev/40 p-6 transition-all hover:border-border-strong hover:bg-bg-elev"
      >
        <div
          class="grid h-10 w-10 place-items-center rounded-md bg-accent/10 text-accent"
          aria-hidden="true"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path
              d="M4 6h16M6 6v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2V6M9 10h6M9 14h6"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </div>
        <h2 class="mt-5 text-base font-semibold text-fg">Legal & press</h2>
        <p class="mt-1.5 text-sm text-fg-muted">
          Trademark, partnerships, press inquiries.
        </p>
        <p class="mt-4 font-mono text-sm text-fg group-hover:text-accent">
          legal@nexutility.com
        </p>
      </a>
    </div>
  </section>

  <section class="container-page pb-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-2xl font-semibold tracking-tight md:text-3xl">
        Frequently asked
      </h2>
      <div class="mt-8 divide-y divide-border rounded-xl border border-border bg-bg-elev/40">
        {
          faqs.map((faq) => (
            <details class="group">
              <summary class="flex cursor-pointer list-none items-start justify-between gap-4 p-6 transition-colors hover:bg-bg-elev">
                <span class="text-base font-medium text-fg">{faq.q}</span>
                <span
                  class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-md border border-border text-fg-muted transition-transform group-open:rotate-45"
                  aria-hidden="true"
                >
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
                    <path
                      d="M12 5v14M5 12h14"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                    />
                  </svg>
                </span>
              </summary>
              <div class="px-6 pb-6 text-sm leading-relaxed text-fg-muted">
                {faq.a}
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
