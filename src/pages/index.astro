---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppCard from "../components/AppCard.astro";
import { apps } from "../data/apps";

const featured = apps.slice(0, 3);

const beliefs = [
  {
    title: "Calm over loud.",
    body: "Software that gets out of your way, not into your face. No streaks to maintain, no notifications dressed up as care, no engagement metrics in the loop.",
  },
  {
    title: "Privacy is the default.",
    body: "Your data stays on your device unless there's a clear reason it shouldn't. Every product comes with a plain-language explanation of what it touches and why.",
  },
  {
    title: "Made for the long run.",
    body: "We pick a small number of products and keep them maintained. Tools shouldn't quietly disappear when a funding round closes or an acquisition swallows the team.",
  },
  {
    title: "A real person reads your email.",
    body: "No chatbots, no copy-paste tickets. When you write, someone reads, and writes back — usually within a working day.",
  },
];

const audiences = [
  {
    title: "Marketplace sellers",
    body: "Calculating real profit across border-crossing platforms — every commission, every payment fee, every shipping cost, modelled honestly.",
    product: "Kârly",
  },
  {
    title: "Families with old photographs",
    body: "Bringing faded, scratched, and torn pictures back to life — without sending the photographs anywhere they don't need to go.",
    product: "Heirloom",
  },
];
---

<BaseLayout title="NexUtility">
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 grid-bg" aria-hidden="true"></div>
    <div
      class="absolute -top-32 left-1/2 h-[480px] w-[680px] -translate-x-1/2 rounded-full bg-accent/10 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative pt-28 pb-24 md:pt-36 md:pb-32">
      <div class="mx-auto max-w-3xl text-center">
        <h1
          class="text-balance text-5xl font-semibold leading-[1.05] tracking-tight md:text-7xl"
        >
          <span class="text-gradient">Tools designed</span>
          <br />
          for human hands.
        </h1>

        <p class="mx-auto mt-8 max-w-2xl text-pretty text-base leading-relaxed text-fg-muted md:text-lg">
          Software that meets you where you are. Tools that respect your
          attention, your data, and the way you actually live.
        </p>

        <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
          <a
            href="#products"
            class="inline-flex min-h-[44px] items-center gap-1.5 rounded-md bg-accent px-5 text-sm font-medium text-accent-foreground transition-colors hover:bg-accent-hover"
          >
            See what we're building
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 5v14m-6-6 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex min-h-[44px] items-center gap-1.5 rounded-md border border-border bg-bg-elev/60 px-5 text-sm font-medium text-fg backdrop-blur transition-colors hover:border-border-strong hover:bg-bg-elev"
          >
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTS -->
  <section id="products" class="container-page py-20 md:py-24 scroll-mt-20">
    <div
      class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end"
    >
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-fg-muted">
          Products
        </p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
          What's live, what's next.
        </h2>
      </div>
      <a
        href="/apps"
        class="inline-flex min-h-[44px] items-center gap-1.5 text-sm text-fg-muted underline-offset-4 transition-colors hover:text-fg hover:underline"
      >
        See everything
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      {featured.map((app) => <AppCard app={app} />)}
    </div>
  </section>

  <!-- WHAT WE BELIEVE -->
  <section id="beliefs" class="container-page py-20 md:py-24 scroll-mt-20">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-fg-muted">
        What we believe
      </p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
        Four lines we won't cross.
      </h2>
      <p class="mt-4 text-fg-muted">
        Every product we ship is held to the same line. If we can't honour all
        four, we don't ship it.
      </p>
    </div>

    <div
      class="mt-14 grid gap-px overflow-hidden rounded-xl border border-border bg-border md:grid-cols-2"
    >
      {
        beliefs.map((b, i) => (
          <div class="bg-bg-elev/40 p-7 transition-colors hover:bg-bg-elev">
            <div class="flex items-center gap-3" aria-hidden="true">
              <span class="font-mono text-xs text-fg-muted">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class="h-px flex-1 bg-border" />
            </div>
            <h3 class="mt-4 text-lg font-semibold text-fg">{b.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-fg-muted">{b.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- WHO WE SERVE -->
  <section class="container-page py-20 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-fg-muted">
        Who we serve
      </p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
        Real people, real situations.
      </h2>
      <p class="mt-4 text-fg-muted">
        We frame our work in terms of human situations — not categories or
        verticals. These are the people we're building for right now.
      </p>
    </div>

    <div class="mt-14 grid gap-5 md:grid-cols-2">
      {
        audiences.map((a) => (
          <div class="flex h-full flex-col rounded-xl border border-border bg-bg-elev/40 p-7 transition-colors hover:bg-bg-elev">
            <h3 class="text-lg font-semibold text-fg">{a.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-fg-muted">{a.body}</p>
            <p class="mt-5 inline-flex items-center gap-2 text-xs font-mono text-fg-muted">
              <span class="h-1 w-1 rounded-full bg-accent" aria-hidden="true" />
              {a.product}
            </p>
          </div>
        ))
      }
    </div>

    <p class="mt-10 text-center text-sm text-fg-muted">
      More on the way. We pick problems where good software makes a daily
      difference, and we work on one carefully at a time so each one earns
      the home-screen spot.
    </p>
  </section>

  <!-- TRANSPARENCY -->
  <section class="container-page py-20 md:py-24">
    <div
      class="overflow-hidden rounded-2xl border border-border bg-gradient-to-br from-bg-elev to-bg-elev/40 p-8 md:p-12"
    >
      <div class="grid gap-8 md:grid-cols-[1.6fr_1fr] md:items-center">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-fg-muted">
            Transparency
          </p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
            What we do — and don't — do with your data.
          </h2>
          <p class="mt-4 max-w-xl text-fg-muted">
            Every product ships with a plain-language privacy policy and terms.
            We disclose what we collect, what we never collect, and which
            outside parties handle data on our behalf — without dressing it up
            in jargon.
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <a
            href="/privacy"
            class="group flex min-h-[48px] items-center justify-between rounded-md border border-border bg-bg/40 px-4 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Privacy Policy</span>
            <span class="text-fg-muted group-hover:text-accent">→</span>
          </a>
          <a
            href="/terms"
            class="group flex min-h-[48px] items-center justify-between rounded-md border border-border bg-bg/40 px-4 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Terms of Service</span>
            <span class="text-fg-muted group-hover:text-accent">→</span>
          </a>
          <a
            href="/support"
            class="group flex min-h-[48px] items-center justify-between rounded-md border border-border bg-bg/40 px-4 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Support</span>
            <span class="text-fg-muted group-hover:text-accent">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
