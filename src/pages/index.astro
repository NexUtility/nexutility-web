---
import BaseLayout from "../layouts/BaseLayout.astro";
import AppCard from "../components/AppCard.astro";
import { apps } from "../data/apps";

const featured = apps.slice(0, 3);

const principles = [
  {
    title: "Utility-first",
    body: "Every app solves a real, recurring problem. No filler, no dark patterns.",
  },
  {
    title: "Cross-platform",
    body: "Built once with Flutter, polished separately for iOS and Android.",
  },
  {
    title: "Honest monetization",
    body: "Optional subscriptions powered by RevenueCat. Ads where they earn their keep.",
  },
  {
    title: "Privacy by default",
    body: "We collect the minimum needed to run the product, and we tell you exactly what.",
  },
];
---

<BaseLayout title="NexUtility">
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 grid-bg" aria-hidden="true"></div>
    <div
      class="absolute -top-32 left-1/2 h-[480px] w-[680px] -translate-x-1/2 rounded-full bg-accent/10 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="container-page relative pt-24 pb-24 md:pt-32 md:pb-32">
      <div class="mx-auto max-w-3xl text-center">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-border bg-bg-elev/60 px-3 py-1 text-xs font-mono text-fg-muted backdrop-blur"
        >
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent opacity-75"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent"></span>
          </span>
          New studio · shipping our first apps
        </span>

        <h1
          class="mt-6 text-balance text-5xl font-semibold leading-[1.05] tracking-tight md:text-7xl"
        >
          <span class="text-gradient">Utility-first</span>
          <br />
          mobile apps,
          <br />
          shipped fast.
        </h1>

        <p class="mx-auto mt-7 max-w-xl text-pretty text-base leading-relaxed text-fg-muted md:text-lg">
          NexUtility is an indie mobile studio. We design and build small,
          focused apps for iOS and Android — the kind you actually keep on your
          home screen.
        </p>

        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/apps"
            class="inline-flex items-center gap-1.5 rounded-md bg-accent px-5 py-2.5 text-sm font-medium text-accent-foreground transition-colors hover:bg-accent-hover"
          >
            Browse our apps
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-1.5 rounded-md border border-border bg-bg-elev/60 px-5 py-2.5 text-sm font-medium text-fg backdrop-blur transition-colors hover:border-border-strong hover:bg-bg-elev"
          >
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PRINCIPLES -->
  <section class="container-page py-20 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-fg-subtle">How we build</p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
        Small team, sharp focus.
      </h2>
      <p class="mt-4 text-fg-muted">
        Four principles run through every NexUtility release.
      </p>
    </div>

    <div class="mt-14 grid gap-px overflow-hidden rounded-xl border border-border bg-border md:grid-cols-2">
      {
        principles.map((p, i) => (
          <div class="bg-bg-elev/40 p-7 transition-colors hover:bg-bg-elev">
            <div class="flex items-center gap-3">
              <span class="font-mono text-xs text-fg-subtle">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class="h-px flex-1 bg-border"></div>
            </div>
            <h3 class="mt-4 text-lg font-semibold text-fg">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-fg-muted">{p.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- FEATURED APPS -->
  <section class="container-page py-20 md:py-24">
    <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
      <div>
        <p class="font-mono text-xs uppercase tracking-widest text-fg-subtle">
          From the catalog
        </p>
        <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
          Apps in the wild.
        </h2>
      </div>
      <a
        href="/apps"
        class="inline-flex items-center gap-1.5 text-sm text-fg-muted underline-offset-4 transition-colors hover:text-fg hover:underline"
      >
        See all apps
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((app) => <AppCard app={app} />)}
    </div>
  </section>

  <!-- TRUST / LEGAL CTA -->
  <section class="container-page py-20 md:py-24">
    <div
      class="overflow-hidden rounded-2xl border border-border bg-gradient-to-br from-bg-elev to-bg-elev/40 p-8 md:p-12"
    >
      <div class="grid gap-8 md:grid-cols-[1.6fr_1fr] md:items-center">
        <div>
          <p class="font-mono text-xs uppercase tracking-widest text-fg-subtle">
            Transparency
          </p>
          <h2 class="mt-3 text-3xl font-semibold tracking-tight md:text-4xl">
            What we do — and don't — do with your data.
          </h2>
          <p class="mt-4 max-w-xl text-fg-muted">
            We disclose every SDK we use, what we collect, and why. Our apps
            comply with Apple App Tracking Transparency, Google Data Safety,
            GDPR, and KVKK from day one.
          </p>
        </div>
        <div class="flex flex-col gap-2">
          <a
            href="/privacy"
            class="group flex items-center justify-between rounded-md border border-border bg-bg/40 px-4 py-3 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Privacy Policy</span>
            <span class="text-fg-subtle group-hover:text-accent">→</span>
          </a>
          <a
            href="/terms"
            class="group flex items-center justify-between rounded-md border border-border bg-bg/40 px-4 py-3 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Terms of Service</span>
            <span class="text-fg-subtle group-hover:text-accent">→</span>
          </a>
          <a
            href="/support"
            class="group flex items-center justify-between rounded-md border border-border bg-bg/40 px-4 py-3 text-sm transition-colors hover:border-border-strong hover:bg-bg/80"
          >
            <span class="font-medium text-fg">Support</span>
            <span class="text-fg-subtle group-hover:text-accent">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
