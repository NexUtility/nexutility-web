---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" description="The page you're looking for doesn't exist." noIndex>
  <section class="container-page flex min-h-[60vh] items-center justify-center py-24">
    <div class="text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-fg-muted">
        Error 404
      </p>
      <h1 class="mt-4 text-5xl font-semibold tracking-tight md:text-6xl">
        <span class="text-gradient">Lost in the catalog.</span>
      </h1>
      <p class="mx-auto mt-5 max-w-md text-fg-muted">
        The page you're looking for doesn't exist — or has moved. Try one of
        the doors below.
      </p>
      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center rounded-md bg-accent px-5 py-2.5 text-sm font-medium text-accent-foreground transition-colors hover:bg-accent-hover"
        >
          Go home
        </a>
        <a
          href="/apps"
          class="inline-flex items-center rounded-md border border-border bg-bg-elev/60 px-5 py-2.5 text-sm font-medium text-fg backdrop-blur transition-colors hover:border-border-strong hover:bg-bg-elev"
        >
          Browse apps
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
